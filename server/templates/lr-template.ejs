<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Challan</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100%;
            font-family: Arial, sans-serif;
            font-size: 10px;
            background: #fff;
        }

        .page-container {
            width: 100%;
            height: 100%;
            padding: 1.5%;
        }

        .outer-box {
            width: 100%;
            height: 100%;
            border: 2px solid #000;
            display: flex;
            flex-direction: column;
        }

        .challan-container {
            width: 100%;
            height: 100%;
            padding: 1% 1.5%;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        /* ── HEADER ── */
        .header-row {
            width: 100%;
            display: flex;
            align-items: center;
            border: 1px solid #000;
            padding: 1% 2%;
            gap: 2%;
        }

        .header-logo {
            width: 5%;
            aspect-ratio: 1.3 / 1;
            object-fit: contain;
            flex-shrink: 0;
        }

        .header-text {
            flex: 1;
            text-align: center;
        }

        .header-company {
            font-size: 14px;
            font-weight: bold;
            line-height: 1.3;
        }

        .header-sub {
            font-size: 9px;
            line-height: 1.4;
        }

        /* ── TITLE BAR ── */
        .title-bar {
            width: 100%;
            text-align: center;
            font-size: 11px;
            font-weight: bold;
            border: 1px solid #000;
            padding: 2px 0;
        }

        /* ── TABLES ── */
        table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        td, th {
            border: 1px solid #000;
            padding: 1.5px 3px;
            vertical-align: top;
            font-size: 9px;
            word-break: break-word;
            overflow-wrap: break-word;
        }

        th {
            background: #e0e0e0;
            font-size: 9px;
            text-align: center;
            font-weight: bold;
        }

        .lbl {
            font-weight: bold;
            font-size: 9px;
        }

        /* ── WIDTHS ── */
        .w20 { width: 20%; }
        .w25 { width: 25%; }
        .w30 { width: 30%; }
        .w33 { width: 33.33%; }
        .w40 { width: 40%; }
        .w50 { width: 50%; }

        /* ── SECTION TITLE ── */
        .section-title {
            font-weight: bold;
            font-size: 9px;
            margin: 1px 0;
        }

        /* ── MISC TEXT ── */
        .misc-line {
            font-size: 9px;
            margin: 1px 0;
        }

        .italic-note {
            font-size: 8px;
            font-style: italic;
            margin: 1px 0;
        }

        /* ── SIGNATURE TABLE ── */
        .sig-table td {
            height: 50px;
            text-align: center;
            vertical-align: middle;
            font-size: 9px;
            font-weight: bold;
        }

        .sig-table img {
            max-width: 80%;
            max-height: 35px;
            display: block;
            margin: 0 auto 2px auto;
        }

        /* ── PRINT ── */
        @page {
            size: A4;
            margin: 0;
        }

        @media print {
            html, body {
                width: 210mm;
                height: 297mm;
                margin: 0;
                padding: 0;
            }
            .page-container {
                width: 210mm;
                height: 297mm;
                padding: 4mm;
            }
        }
    </style>
</head>
<body>
<div class="page-container">
    <div class="outer-box">
        <div class="challan-container">

            <!-- HEADER: logo + company name in same row -->
            <div class="header-row">
                <img src="<%= logoBase64 %>" alt="Logo" class="header-logo">
                <div class="header-text">
                    <div class="header-company">SHREE AARYA LOGISTICS</div>
                    <div class="header-sub">VIJAY NAGAR, INDORE-M.P.-452010</div>
                    <div class="header-sub">CONTACT DETAILS : INDORE +91-91111-91111</div>
                </div>
            </div>

            <!-- TITLE -->
            <div class="title-bar">
                CONSIGNMENT NOTE CUM CHECK LIST - <%= copyType %>
            </div>

            <!-- MAIN INFO TABLE -->
            <table>
                <tbody>
                    <tr>
                        <td class="lbl w25">Challan No:</td>
                        <td class="w25"><%= vehicle.challanNo %></td>
                        <td class="lbl w25" colspan="2" style="text-align:center;"><%= copyType %></td>
                    </tr>
                    <tr>
                        <td class="lbl w25">Name of Consignor:</td>
                        <td class="w25"><%= vehicle.consignorName %></td>
                        <td class="lbl w25">Invoice Date</td>
                        <td class="w25"><%= new Date(vehicle.invoiceDate).toLocaleDateString('en-GB') %></td>
                    </tr>
                    <tr>
                        <td class="lbl w25">Address of Consignor:</td>
                        <td class="w25"><%= vehicle.consignorAddress %></td>
                        <td class="lbl w25">Challan Date</td>
                        <td class="w25"><%= new Date(vehicle.dispatchDate).toLocaleDateString('en-GB') %></td>
                    </tr>
                    <tr>
                        <td class="w25"></td>
                        <td class="w25"></td>
                        <td class="lbl w25">Expected Delivery Date</td>
                        <td class="w25"><%= vehicle.deliveryDate ? new Date(vehicle.deliveryDate).toLocaleDateString('en-GB') : 'N/A' %></td>
                    </tr>
                    <tr>
                        <td class="lbl w25">Name of Depot/Dealer/Customer:</td>
                        <td class="w25"><%= vehicle.consigneeName %></td>
                        <td class="lbl w25">Driver Name</td>
                        <td class="w25"><%= vehicle.driverName %></td>
                    </tr>
                    <tr>
                        <td class="lbl w25">Address of Depot/Dealer/Customer:</td>
                        <td class="w25"><%= vehicle.consigneeAddress %></td>
                        <td class="lbl w25">Place</td>
                        <td class="w25"><%= vehicle.consignorAddress %></td>
                    </tr>
                    <tr>
                        <td class="w25"></td>
                        <td class="w25"></td>
                        <td class="lbl w25">Delivery</td>
                        <td class="w25"><%= vehicle.placeOfDelivery %></td>
                    </tr>
                </tbody>
            </table>

            <!-- VEHICLE DETAILS TABLE -->
            <table>
                <tbody>
                    <tr>
                        <td class="lbl w25">Chassis No:</td>
                        <td class="w25"><%= vehicle.chassisNo %></td>
                        <td class="lbl w25">Vehicle Model:</td>
                        <td class="w25"><%= vehicle.modelDetails %></td>
                    </tr>
                    <tr>
                        <td class="lbl w25">Engine No:</td>
                        <td class="w25"><%= vehicle.engineNo %></td>
                        <td class="lbl w25">Temp Reg No:</td>
                        <td class="w25"><%= vehicle.tempRegNo %></td>
                    </tr>
                    <tr>
                        <td class="lbl w25">Invoice No:</td>
                        <td class="w25"><%= vehicle.invoiceNo %></td>
                        <td class="lbl w25">Insurance No:</td>
                        <td class="w25"><%= vehicle.insuranceNo %></td>
                    </tr>
                    <tr>
                        <td class="lbl w25">Insurance Company:</td>
                        <td class="w25"><%= vehicle.insuranceCompany %></td>
                        <td class="lbl w25">KM Reading:</td>
                        <td class="w25">Start: _______ &nbsp; End: _______</td>
                    </tr>
                </tbody>
            </table>

            <!-- CHECKLIST -->
            <div class="section-title">Checklist (Kindly Tick (✓))</div>
            <table>
                <thead>
                    <tr>
                        <th style="width:52%;">Checklist</th>
                        <th colspan="4" style="width:48%;">Kindly Tick ( ✓ )</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="width:52%;">Invoice Original / Duplicate:</td>
                        <td style="width:12%; text-align:center;">Yes</td>
                        <td style="width:12%;"></td>
                        <td style="width:12%; text-align:center;">No</td>
                        <td style="width:12%;"></td>
                    </tr>
                    <tr>
                        <td>Insurance Paper:</td>
                        <td style="text-align:center;">Yes</td><td></td>
                        <td style="text-align:center;">No</td><td></td>
                    </tr>
                    <tr>
                        <td>T.R.C.:</td>
                        <td style="text-align:center;">Yes</td><td></td>
                        <td style="text-align:center;">No</td><td></td>
                    </tr>
                    <tr>
                        <td>Service Book:</td>
                        <td style="text-align:center;">Yes</td><td></td>
                        <td style="text-align:center;">No</td><td></td>
                    </tr>
                    <tr>
                        <td>Tool Kit:</td>
                        <td style="text-align:center;">Yes</td><td></td>
                        <td style="text-align:center;">No</td><td></td>
                    </tr>
                    <tr>
                        <td>Key Ring:</td>
                        <td style="text-align:center;">Yes</td><td></td>
                        <td style="text-align:center;">No</td><td></td>
                    </tr>
                </tbody>
            </table>

            <!-- RATING TABLE -->
            <table>
                <thead>
                    <tr>
                        <th style="width:40%;">Particular</th>
                        <th style="width:15%;">Very Good</th>
                        <th style="width:15%;">Good</th>
                        <th style="width:15%;">Average</th>
                        <th style="width:15%;">Poor</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="text-align:center;">Delivery on Time</td>
                        <td></td><td></td><td></td><td></td>
                    </tr>
                    <tr>
                        <td style="text-align:center;">Behavior of Incharge</td>
                        <td></td><td></td><td></td><td></td>
                    </tr>
                    <tr>
                        <td style="text-align:center;">Cleanliness of Vehicle</td>
                        <td></td><td></td><td></td><td></td>
                    </tr>
                </tbody>
            </table>

            <!-- DAMAGE & NOTE -->
            <div class="misc-line">Damage if any: ☐ YES &nbsp;&nbsp; ☐ NO &nbsp;&nbsp; E-Mail I'd:</div>
            <div class="italic-note">In case of any damage provide a photograph with incharge of convoy, standing near by the vehicle.</div>

            <!-- PARTNER TABLE -->
            <table>
                <tbody>
                    <tr>
                        <td class="w33">PARTNER NAME:</td>
                        <td class="w33">E-MAIL ID:</td>
                        <td class="w33">CONTACT NO:</td>
                    </tr>
                    <tr>
                        <td colspan="3">FOR TRANSIT RELATED INFORMATION CONTACT: 91-9752092341</td>
                    </tr>
                </tbody>
            </table>

            <!-- REMARKS -->
            <div class="misc-line">At the time of vehicle delivery Diesel in tank 7 Ltrs :-</div>
            <div class="misc-line">In case of Manufacturing / Technical fault :-</div>
            <div class="misc-line">Remark :-</div>
            <div class="misc-line">Any Comments / Suggestion for Improvement of Services :-</div>

            <!-- RECIPIENT TABLE -->
            <table>
                <tbody>
                    <tr>
                        <td class="lbl w25">Receipent Name: <%= vehicle.consigneeName %></td>
                        <td class="w25"></td>
                        <td class="lbl w25">Receipent Mob No.:</td>
                        <td class="w25"></td>
                    </tr>
                </tbody>
            </table>

            <!-- SIGNATURE TABLE -->
            <table class="sig-table">
                <tbody>
                    <tr>
                        <td class="w33">DRIVER SIGNATURE</td>
                        <td class="w33">
                            <% if (signatureUrl) { %>
                                <img src="<%= signatureUrl %>" alt="Signature">
                            <% } %>
                            SIGNATURE &amp; STAMP<br>
                            DELIVERY DATE: <%= vehicle.deliveryDate ? new Date(vehicle.deliveryDate).toLocaleDateString('en-GB') : 'N/A' %>
                        </td>
                        <td class="w33">RECEIPIENT SIGNATURE &amp; STAMP</td>
                    </tr>
                </tbody>
            </table>

        </div><!-- /challan-container -->
    </div><!-- /outer-box -->
</div><!-- /page-container -->
</body>
</html>