<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Challan</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            font-size: 9px;
            background: #fff;
        }

        .page-container {
            width: 210mm;
            min-height: 297mm;
            padding: 4mm;
            margin: 0 auto;
        }

        .outer-box {
            width: 100%;
            border: 2px solid #000;
        }

        .challan-container {
            padding: 3mm;
        }

        /* ── HEADER ── */
        .header-row {
            display: flex;
            align-items: center;
            border-bottom: 1px solid #000;
            padding: 2px 4px;
            gap: 6px;
        }

        .header-logo {
            width: 36px;
            height: 28px;
            object-fit: contain;
            flex-shrink: 0;
        }

        .header-text {
            flex: 1;
            text-align: center;
        }

        .header-company {
            font-size: 13px;
            font-weight: bold;
            line-height: 1.2;
        }

        .header-sub {
            font-size: 8px;
            line-height: 1.3;
        }

        /* ── TITLE BAR ── */
        .title-bar {
            text-align: center;
            font-size: 10px;
            font-weight: bold;
            border: 1px solid #000;
            padding: 2px;
            margin: 3px 0;
        }

        /* ── TABLES ── */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 3px;
        }

        td, th {
            border: 1px solid #000;
            padding: 2px 3px;
            vertical-align: top;
            font-size: 8px;
        }

        th {
            background: #e0e0e0;
            font-size: 8px;
            text-align: center;
        }

        .lbl {
            font-weight: bold;
            white-space: nowrap;
        }

        .w25 { width: 25%; }
        .w33 { width: 33.33%; }

        /* ── SECTION TITLE ── */
        .section-title {
            font-weight: bold;
            font-size: 8px;
            margin: 3px 0 2px 0;
        }

        /* ── MISC TEXT ── */
        .misc-line {
            font-size: 8px;
            margin: 2px 0;
        }

        .italic-note {
            font-size: 7.5px;
            font-style: italic;
            margin: 2px 0;
        }

        /* ── SIGNATURE TABLE ── */
        .sig-table td {
            height: 40px;
            text-align: center;
            vertical-align: top;
            font-size: 8px;
            font-weight: bold;
        }

        .sig-table img {
            max-width: 80px;
            max-height: 35px;
            display: block;
            margin: 0 auto 2px auto;
        }

        /* ── PRINT ── */
        @page {
            size: A4;
            margin: 0;
        }

        @media print {
            body { margin: 0; }
            .page-container {
                width: 210mm;
                padding: 4mm;
            }
        }
    </style>
</head>
<body>
<div class="page-container">
    <div class="outer-box">
        <div class="challan-container">

            <!-- HEADER: logo + company name in same row -->
            <div class="header-row">
                <img src="<%= logoBase64 %>" alt="Logo" class="header-logo">
                <div class="header-text">
                    <div class="header-company">SHREE AARYA LOGISTICS</div>
                    <div class="header-sub">VIJAY NAGAR, INDORE-M.P.-452010</div>
                    <div class="header-sub">CONTACT DETAILS : INDORE +91-91111-91111</div>
                </div>
            </div>

            <!-- TITLE -->
            <div class="title-bar">
                CONSIGNMENT NOTE CUM CHECK LIST - <%= copyType %>
            </div>

            <!-- MAIN INFO TABLE -->
            <table>
                <tbody>
                    <tr>
                        <td class="lbl w25">Challan No:</td>
                        <td class="w25"><%= vehicle.challanNo %></td>
                        <td class="lbl" colspan="2" style="text-align:center;"><%= copyType %></td>
                    </tr>
                    <tr>
                        <td class="lbl">Name of Consignor:</td>
                        <td><%= vehicle.consignorName %></td>
                        <td class="lbl">Invoice Date</td>
                        <td><%= new Date(vehicle.invoiceDate).toLocaleDateString('en-GB') %></td>
                    </tr>
                    <tr>
                        <td class="lbl">Address of Consignor:</td>
                        <td><%= vehicle.consignorAddress %></td>
                        <td class="lbl">Challan Date</td>
                        <td><%= new Date(vehicle.dispatchDate).toLocaleDateString('en-GB') %></td>
                    </tr>
                    <tr>
                        <td></td>
                        <td></td>
                        <td class="lbl">Expected Delivery Date</td>
                        <td><%= vehicle.deliveryDate ? new Date(vehicle.deliveryDate).toLocaleDateString('en-GB') : 'N/A' %></td>
                    </tr>
                    <tr>
                        <td class="lbl">Name of Depot/Dealer/Customer:</td>
                        <td><%= vehicle.consigneeName %></td>
                        <td class="lbl">Driver Name</td>
                        <td><%= vehicle.driverName %></td>
                    </tr>
                    <tr>
                        <td class="lbl">Address of Depot/Dealer/Customer:</td>
                        <td><%= vehicle.consigneeAddress %></td>
                        <td class="lbl">Place</td>
                        <td><%= vehicle.consignorAddress %></td>
                    </tr>
                    <tr>
                        <td></td>
                        <td></td>
                        <td class="lbl">Delivery</td>
                        <td><%= vehicle.placeOfDelivery %></td>
                    </tr>
                </tbody>
            </table>

            <!-- VEHICLE DETAILS TABLE -->
            <table>
                <tbody>
                    <tr>
                        <td class="lbl w25">Chassis No:</td>
                        <td class="w25"><%= vehicle.chassisNo %></td>
                        <td class="lbl w25">Vehicle Model:</td>
                        <td class="w25"><%= vehicle.modelDetails %></td>
                    </tr>
                    <tr>
                        <td class="lbl">Engine No:</td>
                        <td><%= vehicle.engineNo %></td>
                        <td class="lbl">Temp Reg No:</td>
                        <td><%= vehicle.tempRegNo %></td>
                    </tr>
                    <tr>
                        <td class="lbl">Invoice No:</td>
                        <td><%= vehicle.invoiceNo %></td>
                        <td class="lbl">Insurance No:</td>
                        <td><%= vehicle.insuranceNo %></td>
                    </tr>
                    <tr>
                        <td class="lbl">Insurance Company:</td>
                        <td><%= vehicle.insuranceCompany %></td>
                        <td class="lbl">KM Reading:</td>
                        <td>Start: _______ End: _______</td>
                    </tr>
                </tbody>
            </table>

            <!-- CHECKLIST -->
            <div class="section-title">Checklist (Kindly Tick (✓))</div>
            <table>
                <thead>
                    <tr>
                        <th colspan="1">Checklist</th>
                        <th colspan="4">Kindly Tick ( ✓ )</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Invoice Original / Duplicate:</td>
                        <td>Yes</td><td></td>
                        <td>No</td><td></td>
                    </tr>
                    <tr>
                        <td>Insurance Paper:</td>
                        <td>Yes</td><td></td>
                        <td>No</td><td></td>
                    </tr>
                    <tr>
                        <td>T.R.C.:</td>
                        <td>Yes</td><td></td>
                        <td>No</td><td></td>
                    </tr>
                    <tr>
                        <td>Service Book:</td>
                        <td>Yes</td><td></td>
                        <td>No</td><td></td>
                    </tr>
                    <tr>
                        <td>Tool Kit:</td>
                        <td>Yes</td><td></td>
                        <td>No</td><td></td>
                    </tr>
                    <tr>
                        <td>Key Ring:</td>
                        <td>Yes</td><td></td>
                        <td>No</td><td></td>
                    </tr>
                </tbody>
            </table>

            <!-- RATING TABLE -->
            <table>
                <thead>
                    <tr>
                        <th>Particular</th>
                        <th>Very Good</th>
                        <th>Good</th>
                        <th>Average</th>
                        <th>Poor</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="text-align:center;">Delivery on Time</td>
                        <td></td><td></td><td></td><td></td>
                    </tr>
                    <tr>
                        <td style="text-align:center;">Behavior of Incharge</td>
                        <td></td><td></td><td></td><td></td>
                    </tr>
                    <tr>
                        <td style="text-align:center;">Cleanliness of Vehicle</td>
                        <td></td><td></td><td></td><td></td>
                    </tr>
                </tbody>
            </table>

            <!-- DAMAGE & NOTE -->
            <div class="misc-line">Damage if any: ☐ YES &nbsp;&nbsp; ☐ NO &nbsp;&nbsp; E-Mail I'd:</div>
            <div class="italic-note">In case of any damage provide a photograph with incharge of convoy, standing near by the vehicle.</div>

            <!-- PARTNER TABLE -->
            <table>
                <tbody>
                    <tr>
                        <td class="w33">PARTNER NAME:</td>
                        <td class="w33">E-MAIL ID:</td>
                        <td class="w33">CONTACT NO:</td>
                    </tr>
                    <tr>
                        <td colspan="3">FOR TRANSIT RELATED INFORMATION CONTACT: 91-9752092341</td>
                    </tr>
                </tbody>
            </table>

            <!-- REMARKS -->
            <div class="misc-line">At the time of vehicle delivery Diesel in tank 7 Ltrs :-</div>
            <div class="misc-line">In case of Manufacturing / Technical fault :-</div>
            <div class="misc-line">Remark :-</div>
            <div class="misc-line">Any Comments / Suggestion for Improvement of Services :-</div>

            <!-- RECIPIENT TABLE -->
            <table>
                <tbody>
                    <tr>
                        <td class="w25 lbl">Receipent Name: <%= vehicle.consigneeName %></td>
                        <td class="w25"></td>
                        <td class="w25 lbl">Receipent Mob No.:</td>
                        <td class="w25"></td>
                    </tr>
                </tbody>
            </table>

            <!-- SIGNATURE TABLE -->
            <table class="sig-table" style="margin-top: 4px;">
                <tr>
                    <td class="w33">DRIVER SIGNATURE</td>
                    <td class="w33">
                        <% if (signatureUrl) { %>
                            <img src="<%= signatureUrl %>" alt="Signature">
                        <% } %>
                        SIGNATURE &amp; STAMP<br>
                        DELIVERY DATE: <%= vehicle.deliveryDate ? new Date(vehicle.deliveryDate).toLocaleDateString('en-GB') : 'N/A' %>
                    </td>
                    <td class="w33">RECEIPIENT SIGNATURE &amp; STAMP</td>
                </tr>
            </table>

        </div><!-- /challan-container -->
    </div><!-- /outer-box -->
</div><!-- /page-container -->
</body>
</html>