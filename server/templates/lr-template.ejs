<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Challan</title>

<style>
body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    font-size: 8px;
}

.page-container {
    width: 100%;
    padding: 3%;
    box-sizing: border-box;
}

.outer-box {
    border: 2px solid black;
}

.challan-container {
    padding: 10px;
}

/* Tables */
table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 6px;
}

td, th {
    border: 1px solid black;
    padding: 5px;
    font-size: 8px;
}

th, .font-semibold {
    font-size: 9px;
    font-weight: bold;
}

.text-center { text-align: center; }

@page {
    size: A4;
    margin: 0;
}
</style>
</head>

<body>

<div class="page-container">
<div class="outer-box">
<div class="challan-container">

<!-- HEADER -->
<div style="border:1px solid black; margin-bottom:6px; padding:6px;">
    <div style="display:flex; align-items:center; width:100%;">

        <!-- LEFT LOGO -->
        <div style="width:80px;">
            <img src="<%= logoBase64 %>" style="width:80px; height:40px; object-fit:contain;">
        </div>

        <!-- CENTER TEXT -->
        <div style="flex-grow:1; text-align:center; line-height:1.2;">
            <div style="font-size:18px; font-weight:bold;">
                SHREE AARYA LOGISTICS
            </div>
            <div style="font-size:12px;">
                VIJAY NAGAR, INDORE-M.P.-452010
            </div>
            <div style="font-size:12px;">
                CONTACT DETAILS : INDORE +91-91111-91111
            </div>
            <div style="font-size:12px; font-weight:600;">
                CONSIGNMENT NOTE CUM CHECK LIST - <%= copyType %>
            </div>
        </div>

        <!-- RIGHT SPACE -->
        <div style="width:80px;"></div>

    </div>
</div>

<!-- MAIN TABLE -->
<table>
<tr>
    <td class="font-semibold">Challan No:</td>
    <td><%= vehicle.challanNo %></td>
    <td class="font-semibold text-center" colspan="2"><%= copyType %></td>
</tr>
<tr>
    <td class="font-semibold">Name of Consignor:</td>
    <td><%= vehicle.consignorName %></td>
    <td class="font-semibold">Invoice Date</td>
    <td><%= new Date(vehicle.invoiceDate).toLocaleDateString('en-GB') %></td>
</tr>
<tr>
    <td class="font-semibold">Address of Consignor:</td>
    <td><%= vehicle.consignorAddress %></td>
    <td class="font-semibold">Challan Date</td>
    <td><%= new Date(vehicle.dispatchDate).toLocaleDateString('en-GB') %></td>
</tr>
<tr>
    <td></td>
    <td></td>
    <td class="font-semibold">Expected Delivery Date</td>
    <td><%= vehicle.deliveryDate ? new Date(vehicle.deliveryDate).toLocaleDateString('en-GB') : 'N/A' %></td>
</tr>
<tr>
    <td class="font-semibold">Name of Depot/Dealer/Customer:</td>
    <td><%= vehicle.consigneeName %></td>
    <td class="font-semibold">Driver Name</td>
    <td><%= vehicle.driverName %></td>
</tr>
<tr>
    <td class="font-semibold">Address of Depot/Dealer/Customer:</td>
    <td><%= vehicle.consigneeAddress %></td>
    <td class="font-semibold">Place</td>
    <td><%= vehicle.consignorAddress %></td>
</tr>
<tr>
    <td></td>
    <td></td>
    <td class="font-semibold">Delivery</td>
    <td><%= vehicle.placeOfDelivery %></td>
</tr>
</table>

<!-- VEHICLE TABLE -->
<table>
<tr>
    <td class="font-semibold">Chassis No:</td>
    <td><%= vehicle.chassisNo %></td>
    <td class="font-semibold">Vehicle Model:</td>
    <td><%= vehicle.modelDetails %></td>
</tr>
<tr>
    <td class="font-semibold">Engine No:</td>
    <td><%= vehicle.engineNo %></td>
    <td class="font-semibold">Temp Reg No:</td>
    <td><%= vehicle.tempRegNo %></td>
</tr>
<tr>
    <td class="font-semibold">Invoice No:</td>
    <td><%= vehicle.invoiceNo %></td>
    <td class="font-semibold">Insurance No:</td>
    <td><%= vehicle.insuranceNo %></td>
</tr>
<tr>
    <td class="font-semibold">Insurance Company:</td>
    <td><%= vehicle.insuranceCompany %></td>
    <td class="font-semibold">KM Reading:</td>
    <td>Start: ______ End: ______</td>
</tr>
</table>

<!-- CHECKLIST -->
<div style="font-size:13px; font-weight:bold; margin:6px 0;">
    Checklist (Kindly Tick (✓))
</div>

<table>
<tr>
    <th>Checklist</th>
    <th colspan="4">Kindly Tick (✓)</th>
</tr>
<tr><td>Invoice Original / Duplicate:</td><td>Yes</td><td></td><td>No</td><td></td></tr>
<tr><td>Insurance Paper:</td><td>Yes</td><td></td><td>No</td><td></td></tr>
<tr><td>T.R.C.:</td><td>Yes</td><td></td><td>No</td><td></td></tr>
<tr><td>Service Book:</td><td>Yes</td><td></td><td>No</td><td></td></tr>
<tr><td>Tool Kit:</td><td>Yes</td><td></td><td>No</td><td></td></tr>
<tr><td>Key Ring:</td><td>Yes</td><td></td><td>No</td><td></td></tr>
</table>

<!-- NOTES -->
<div style="font-size:10px; margin-top:6px;">
    Damage if any: ☐ YES ☐ NO E-Mail I'd:
</div>

<div style="font-size:10px; margin-top:4px;">
    In case of any damage provide a photograph with incharge of convoy.
</div>

<!-- SIGNATURE -->
<table style="margin-top:20px;">
<tr>
    <td style="height:80px;" class="text-center">DRIVER SIGNATURE</td>
    <td class="text-center">
        <% if (signatureUrl) { %>
        <img src="<%= signatureUrl %>" style="max-width:120px;">
        <% } %>
        <br>SIGNATURE & STAMP
    </td>
    <td class="text-center">RECEIPIENT SIGNATURE</td>
</tr>
</table>

</div>
</div>
</div>

</body>
</html>